---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  sector: string;
  date: Date;
  tags?: string[];
}

const { title, description, sector, date, tags = [] } = Astro.props;

const formatted = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<Base title={title} description={description} sector={sector}>
  <div class="container post-wrapper">
    <header class="post-header">
      <p class="sector-label"><span class="sector-num">//</span> {sector.toLowerCase()}</p>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <span class="post-date">{formatted}</span>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
      </div>
    </header>

    <article class="dialog-box prose">
      <slot />
    </article>

    <footer class="post-footer">
      <a href={`/${sector.toLowerCase()}`} class="btn-retro-outline btn-retro">
        ← back
      </a>
    </footer>
  </div>
</Base>

<style>
  .post-wrapper {
    padding: 3.5rem 1.5rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: 1.7rem;
    margin: 0.6rem 0 1rem;
    line-height: 1.3;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-meta);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .prose {
    line-height: 1.8;
    max-width: 72ch;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 600px) {
    .post-wrapper {
      padding: 2rem 1rem;
    }

    .post-title {
      font-size: 1.35rem;
    }

    .dialog-box {
      padding: 1.25rem;
    }

    pre {
      padding: 1rem;
    }
  }
</style>
