---
import Base from '../layouts/Base.astro';
---

<Base title="Home" description="Security researcher & developer. Interactive portfolio with retro FPS tour.">
  <div class="landing">
    <!-- CRT screen frame -->
    <div class="crt-frame">
      <div class="crt-inner">
        <div class="title-block">
          <p class="pre-title">// LOADING PROFILE...</p>
          <h1 class="site-title cursor-blink">ndzekic.dev</h1>
          <p class="tagline">security researcher &amp; developer</p>
        </div>

        <div class="divider">──────────────────────</div>

        <nav class="main-menu">
          <p class="menu-prompt">SELECT MODE:</p>

          <a href="/blog" class="menu-item">
            <span class="menu-arrow">▶</span>
            <span class="menu-key">[ B ]</span>
            <span class="menu-label">BLOG</span>
            <span class="menu-desc">dev notes &amp; writeups</span>
          </a>

          <a href="/research" class="menu-item">
            <span class="menu-arrow">▶</span>
            <span class="menu-key">[ R ]</span>
            <span class="menu-label">RESEARCH</span>
            <span class="menu-desc">CVEs, bounties &amp; techniques</span>
          </a>
        </nav>

        <div class="divider">──────────────────────</div>

        <footer class="landing-footer">
          <a href="https://github.com/nikoladzekic" class="footer-link" target="_blank" rel="noopener">GITHUB</a>
          <span class="footer-sep">//</span>
          <a href="https://www.linkedin.com/in/nikola-dzekic/" class="footer-link" target="_blank" rel="noopener">LINKEDIN</a>
        </footer>
      </div>
    </div>
  </div>
</Base>

<script>
  const routes: Record<string, string> = {
    KeyB: '/blog',
    KeyR: '/research',
  };

  window.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    const path = routes[e.code];
    if (path) window.location.href = path;
  });
</script>

<style>
  .landing {
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .crt-frame {
    border: 3px solid var(--green-dim);
    box-shadow: var(--glow-green), inset 0 0 40px rgba(57,255,20,0.03);
    max-width: 560px;
    width: 100%;
  }

  .crt-inner {
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .pre-title {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    margin-bottom: 0.75rem;
  }

  .site-title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    text-shadow: var(--glow-green);
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text-dim);
    margin: 0;
  }

  .divider {
    font-family: var(--font-mono);
    color: var(--border);
    font-size: 1rem;
    letter-spacing: 0.1em;
  }

  .main-menu {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .menu-prompt {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
  }

  .menu-item {
    display: grid;
    grid-template-columns: 1rem 2.5rem 7rem 1fr;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.5rem;
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 1.15rem;
    border: 1px solid transparent;
    transition: border-color 0.1s, background 0.1s;
  }

  .menu-item:hover {
    border-color: var(--green-dim);
    background: rgba(57, 255, 20, 0.04);
  }

  .menu-arrow {
    font-size: 0.6rem;
    color: var(--text-muted);
  }

  .menu-item:hover .menu-arrow {
    color: var(--green);
  }

  .menu-key {
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    color: var(--amber);
    letter-spacing: 0.05em;
  }

  .menu-label {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: inherit;
    letter-spacing: 0.05em;
  }

  .menu-desc {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .landing-footer {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-link {
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.1s;
  }

  .footer-link:hover {
    color: var(--green);
  }

  .footer-sep {
    color: var(--border);
    font-family: var(--font-mono);
  }
</style>
