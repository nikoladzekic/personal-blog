---
import Base from '../layouts/Base.astro';
---

<Base title="404" description="Sector not found." sector="error">
  <div class="not-found">
    <div class="error-frame">
      <p class="error-code">404</p>
      <h1 class="error-title">sector not found</h1>
      <p class="error-msg">The coordinates you entered do not exist on this map.</p>
      <hr class="error-rule" />
      <nav class="error-nav">
        <a href="/" class="error-link">▶ return home</a>
        <a href="/blog" class="error-link">▶ blog</a>
        <a href="/research" class="error-link">▶ research</a>
        <a href="/tour" class="error-link error-link--tour">▶ interactive tour</a>
      </nav>
    </div>
  </div>
</Base>

<style>
  .not-found {
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .error-frame {
    border: 1px solid var(--border-bright);
    background: var(--bg-surface);
    max-width: 520px;
    width: 100%;
    padding: 3rem 2.5rem;
    text-align: center;
  }

  .error-code {
    font-family: var(--font-pixel);
    font-size: 2rem;
    color: var(--accent);
    margin: 0 0 1rem;
    letter-spacing: 0.1em;
  }

  .error-title {
    font-size: 1.3rem;
    margin: 0 0 1rem;
  }

  .error-msg {
    color: var(--text-dim);
    margin: 0 0 1.5rem;
  }

  .error-rule {
    margin: 0 0 1.5rem;
  }

  .error-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .error-link {
    font-family: var(--font-meta);
    font-size: 0.85rem;
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 0.08em;
    transition: color 0.15s;
  }

  .error-link:hover {
    color: var(--primary);
  }

  .error-link--tour {
    color: var(--accent);
  }

  .error-link--tour:hover {
    color: var(--accent);
  }
</style>
