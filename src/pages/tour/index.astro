---
import Base from '../../layouts/Base.astro';
---

<Base title="Tour" description="Interactive 3D tour — coming soon.">
  <div class="coming-soon">
    <div class="terminal-frame">
      <div class="terminal-titlebar">
        <span class="dot dot-red"></span>
        <span class="dot dot-amber"></span>
        <span class="dot dot-green"></span>
        <span class="titlebar-label">TOUR_MODULE.exe</span>
      </div>
      <div class="terminal-body">
        <p class="line"><span class="prompt">$</span> ./launch_tour</p>
        <p class="line output">[ERR] Module not yet compiled.</p>
        <p class="line output">[ERR] Binary missing or incomplete.</p>
        <p class="line">&nbsp;</p>
        <p class="line"><span class="prompt">$</span> status --verbose</p>
        <p class="line output">[INFO] Interactive 3D tour is under active development.</p>
        <p class="line output">[INFO] FPS room exploration — coming soon.</p>
        <p class="line">&nbsp;</p>
        <p class="line output label">STATUS<span class="badge-wip">WIP</span></p>
        <p class="line">&nbsp;</p>
        <p class="line cursor-blink"><span class="prompt">$</span></p>
      </div>
    </div>

    <nav class="back-nav">
      <a href="/" class="back-link">← BACK TO HOME</a>
    </nav>
  </div>
</Base>

<style>
  .coming-soon {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    gap: 2rem;
  }

  .terminal-frame {
    border: 2px solid var(--green-dim);
    max-width: 560px;
    width: 100%;
    box-shadow: var(--glow-green), inset 0 0 40px rgba(57, 255, 20, 0.02);
  }

  .terminal-titlebar {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-red   { background: var(--red); }
  .dot-amber { background: var(--amber); }
  .dot-green { background: var(--green-dim); }

  .titlebar-label {
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    color: var(--text-muted);
    margin-left: 0.5rem;
    letter-spacing: 0.08em;
  }

  .terminal-body {
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    background: var(--bg-surface);
  }

  .line {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text);
    margin: 0;
    line-height: 1.7;
  }

  .prompt {
    color: var(--green);
    margin-right: 0.6rem;
    font-weight: bold;
  }

  .output {
    color: var(--text-dim);
    padding-left: 1.5rem;
  }

  .label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-left: 1.5rem;
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
    margin-top: 0.25rem;
  }

  .badge-wip {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    background: var(--amber);
    color: #0d0d0d;
    padding: 0.25rem 0.5rem;
    letter-spacing: 0.08em;
  }

  .back-nav {
    text-align: center;
  }

  .back-link {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.1s;
  }

  .back-link:hover {
    color: var(--green);
  }
</style>
