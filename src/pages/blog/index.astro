---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = posts[0]?.data.date.toLocaleDateString('en-GB', {
  year: 'numeric', month: 'long',
});
---

<Base title="Blog" sector="blog">
  <div class="container page-wrapper">
    <header class="page-header">
      <p class="sector-label"><span class="sector-num">01</span> · blog</p>
      <h1 class="page-title">dev notes</h1>
      <p class="page-count">
        {posts.length} {posts.length === 1 ? 'entry' : 'entries'}{latest && ` · latest ${latest}`}
      </p>
      <p class="page-desc">
        Software engineering, tooling, and whatever I'm tinkering with.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="empty">// no entries found</p>
    ) : (
      <ul class="rpg-menu post-list">
        {posts.map(post => {
          const date = post.data.date.toLocaleDateString('en-GB', {
            year: 'numeric', month: 'short', day: '2-digit',
          });

          return (
            <li>
              <a href={`/blog/${post.id}`}>
                <span class="entry-body">
                  <span class="entry-date">{date}</span>
                  <span class="entry-title">{post.data.title}</span>
                  {post.data.tags.length > 0 && (
                    <span class="entry-tags">
                      {post.data.tags.slice(0, 3).map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </span>
                  )}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </div>
</Base>

<style>
  .page-wrapper {
    padding: 3.5rem 1.5rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-title {
    text-transform: lowercase;
    margin: 0.5rem 0 0.35rem;
  }

  .page-count {
    font-family: var(--font-meta);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .page-desc {
    color: var(--text-dim);
    margin: 0;
    max-width: 56ch;
  }

  .entry-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .entry-date {
    font-family: var(--font-meta);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .entry-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .rpg-menu a:hover .entry-title {
    color: var(--primary);
  }

  .entry-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.15rem;
  }

  .empty {
    font-family: var(--font-meta);
    color: var(--text-muted);
    padding: 2rem 0;
  }

  @media (max-width: 600px) {
    .page-wrapper {
      padding: 2rem 1rem;
    }
  }
</style>
