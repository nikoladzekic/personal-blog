---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Blog" sector="BLOG">
  <div class="container page-wrapper">
    <header class="page-header">
      <p class="sector-label">BLOG</p>
      <h1 class="page-title cursor-blink">DEV NOTES</h1>
      <p class="page-desc">
        Software engineering, tooling, and whatever I'm tinkering with.
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="empty">// NO ENTRIES FOUND</p>
    ) : (
      <ul class="rpg-menu post-list">
        {posts.map(post => {
          const date = post.data.date.toLocaleDateString('en-GB', {
            year: 'numeric', month: 'short', day: '2-digit',
          }).toUpperCase();

          return (
            <li>
              <a href={`/blog/${post.id}`}>
                <span class="entry-title">{post.data.title}</span>
                <span class="entry-meta">
                  <span class="entry-date">{date}</span>
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </div>
</Base>

<style>
  .page-wrapper {
    padding: 3rem 1.5rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-size: 0.9rem;
    margin: 0.5rem 0 1rem;
  }

  .page-desc {
    font-size: 1.1rem;
    color: var(--text-dim);
    margin: 0;
  }

  .post-list a {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
  }

  .entry-title {
    font-family: var(--font-pixel);
    font-size: 0.65rem;
    color: var(--text);
    line-height: 1.7;
    letter-spacing: 0.04em;
  }

  .rpg-menu a:hover .entry-title {
    color: var(--green);
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .entry-date {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .empty {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    padding: 2rem 0;
  }
</style>
